# ====================================
# MotorConnect — Variables de Entorno
# ====================================
# Copia este archivo como .env y rellena los valores.
# Para desarrollo local con Docker: cp .env.example .env

# === SUPABASE ===
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# === OPENAI / LLM ===
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# === VECTOR STORE (Supabase table) ===
VECTOR_TABLE=manuales_chunks
VECTOR_MATCH_COUNT=5

# === DATABASE (PostgreSQL) ===
DATABASE_URL=postgresql+asyncpg://motorconnect:localdev123@db:5432/motorconnect_db
DB_USER=motorconnect
DB_PASSWORD=localdev123
DB_NAME=motorconnect_db

# === AUTH ===
JWT_SECRET=your-super-secret-key-change-in-production-123456789
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# === BACKEND ===
API_PORT=8000

# === MongoDB (NoSQL Logs) ===
MONGO_USER=motorconnect
MONGO_PASSWORD=localdev123
MONGO_URI=mongodb://motorconnect:localdev123@mongodb:27017/motorconnect_logs
MONGO_DB_NAME=motorconnect_logs

# === Redis (Active Sessions) ===
REDIS_URL=redis://redis:6379/0

# === GROQ (Voice Transcription) ===
GROQ_API_KEY=

# === Qdrant ===
QDRANT_API_KEY=qdrant-key
